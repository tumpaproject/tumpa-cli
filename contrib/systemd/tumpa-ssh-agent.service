[Unit]
Description=Tumpa SSH agent
Documentation=https://github.com/tumpaproject/tumpa-cli
After=graphical-session-pre.target
# Mutually exclusive with the combined service (both bind
# $XDG_RUNTIME_DIR/tcli-ssh.sock).
Conflicts=tumpa-agent.service

[Service]
Type=simple
# NOTE: this path assumes `cargo install tumpa-cli`. Override if your
# binary lives elsewhere (e.g. /usr/local/bin/tcli or /usr/bin/tcli).
ExecStart=%h/.cargo/bin/tcli ssh-agent -H unix://%t/tcli-ssh.sock
EnvironmentFile=-%h/.config/tumpa/env
Restart=on-failure
RestartSec=2
MemoryDenyWriteExecute=true
NoNewPrivileges=true
# The three Protect* directives below rely on unprivileged user
# namespaces. Fedora enables them by default; Debian/Ubuntu restrict
# them, so the service fails to start there. Uncomment on Fedora (or
# any system with unprivileged userns enabled) to harden further.
# ProtectControlGroups=true
# ProtectKernelModules=true
# ProtectKernelTunables=true
RestrictRealtime=true
RestrictSUIDSGID=true

[Install]
WantedBy=default.target
